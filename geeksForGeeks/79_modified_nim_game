// User function Template for Java

class Solution {
    static int findWinner(int n, int A[]) {
        // code here
        

       int xor =Arrays.stream(A).reduce(0, (a,b) -> a^b);
       
      if(xor==0 || n%2==0) return 1;
      
 
      return 2;
    }
}
