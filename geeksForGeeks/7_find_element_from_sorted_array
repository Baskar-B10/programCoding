input arr[] = [4,5,6,7,8,1,2,3], key=3
output :8
logic:
check if element match return the index
else return -1
class Solution {
    int search(int[] arr, int key) {
        // code here
        for (int i=0; i<arr.length; i++){
            if(arr[i]==key){
                return i;
            }
        }
        return -1;
    }
}
