input 1 3 2 4
output: 3,4,4 , -1

logic:
  1. iterate from backward till 0
  2. use stack to store the current element for next iteration
  3. remove the small element in stack in comapre tocurrent element
  4. check if stack is empty so no greater element else take the first element from stack
  
class Solution {
    public ArrayList<Integer> nextLargerElement(int[] arr) {
        // code here
      ArrayList<Integer> output= new ArrayList<>();
        Stack<Integer> stack = new Stack<>();
        int n = arr.length;
        int[] result = new int[n];
        
        for(int i=n-1; i>=0;i--){
            
            while (!stack.isEmpty() && arr[i]>=stack.peek()){
                stack.pop();
            }
            
            result[i] = stack.isEmpty() ? -1 : stack.peek();
            
            stack.push(arr[i]);
        }
        for(int a: result){
            output.add(a);
        }
        return output;
    }
}
