int[] arr = {1,3,-1,-3,5,3,6,7};
int k = 3;

output: [3, 3, 5, 5, 6, 7]

logic:
  1. use dequeue to store index
  2. iterate element check if not empty and remove the first element
  3. check if not empty and remove small element by checking with other element
  4. offer last add the index
  5. if i less than k-1 , add the max element in output

class Solution {
    public ArrayList<Integer> maxOfSubarrays(int[] arr, int k) {
        // code here
        ArrayList<Integer> output = new ArrayList<>();
        Deque<Integer> dq= new LinkedList<>();
  
        for(int i=0; i< arr.length; i++){

            while(!dq.isEmpty() && dq.peekFirst()<= i-k){
                dq.pollFirst();
            }
           while(!dq.isEmpty() && arr[dq.peekLast()] < arr[i]){
               dq.pollLast();
           }
           dq.offerLast(i);
           
           if(i>= k-1){
               output.add(arr[dq.peekFirst()]);
           }
        }
        return output;
    }
}
