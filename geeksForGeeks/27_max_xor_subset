🔹 Dry Run (Quick)
    arr = [2, 4, 5]
    Binary:
        2 = 010
        4 = 100
        5 = 101
    Build basis:
      basis[2] = 4
      basis[1] = 2
      basis[0] = 1   (after reduction from 5)
    Now maximize: 0 → 4 → 6 → 7

  public class MaxSubsetXOR {
    public static int maxSubsetXOR(int[] arr) {

        int[] basis = new int[32];

        // Build basis
        for (int num : arr) {
            int x = num;

            for (int bit = 31; bit >= 0; bit--) {

                if ((x & (1 << bit)) == 0) continue;

                if (basis[bit] == 0) {
                    basis[bit] = x;
                    break;
                }

                x ^= basis[bit];
            }
        }

        // Build maximum XOR
        int result = 0;

        for (int bit = 31; bit >= 0; bit--) {
            if ((result ^ basis[bit]) > result) {
                result ^= basis[bit];
            }
        }

        return result;
    }

    public static void main(String[] args) {
        int[] arr = {2, 4, 5};
        System.out.println(maxSubsetXOR(arr)); // 7
    }
}
